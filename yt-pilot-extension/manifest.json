{
  "manifest_version": 2,
  "name": "YT Pilot",
  "version": "1.0",
  "description": "Zdalne sterowanie YouTube",
  "permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content.js"]
    }
  ]
}